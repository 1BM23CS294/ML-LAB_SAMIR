Reasoning: Implement the predict_one function as described, which calculates the Euclidean distance from a test point to all training points, sorts them, selects the top k neighbors, and returns the most frequent class among them.


from collections import Counter

def predict_one(test_point, X_train, y_train, k):
    """Predicts the class of a single test point using KNN."""
    distances = []
    for i, train_point in enumerate(X_train.values):
        dist = euclidean_distance(test_point, train_point)
        distances.append((dist, y_train.iloc[i]))

    distances.sort(key=lambda x: x[0])

    k_nearest_neighbors = distances[:k]
    k_nearest_labels = [label for dist, label in k_nearest_neighbors]

    most_common = Counter(k_nearest_labels).most_common(1)
    return most_common[0][0]

